# Função para detectar palavras-chave de PEDIDO
def detectar_pedido(mensagem):
    palavras_pedido = [
        "pedido", "encomendar", "pedir", "fazer pedido", "como encomendar",
        "onde faz", "qual é o link", "como peço", "como faço",
        "quero pedir", "gostaria de pedir", "pedir um poke",
        "onde esta meu pedido", "status do pedido", "rastrear pedido"
    ]
    return any(palavra in mensagem.lower() for palavra in palavras_pedido)

# Função para detectar palavras-chave de CARDÁPIO
def detectar_cardapio(mensagem):
    palavras_cardapio = [
        "cardápio", "menu", "o que vocês têm", "qual é o cardápio",
        "qual é o menu", "quais pratos", "que pokes", "que entradas",
        "que bebidas", "veja o cardápio", "mostre o menu"
    ]
    return any(palavra in mensagem.lower() for palavra in palavras_cardapio)

# Função para salvar chat
CHAT_FILE = "chat_historico.txt"
def salvar_chat(usuario_msg, bot_msg):
    try:
        timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        with open(CHAT_FILE, "a", encoding="utf-8") as f:
            f.write(f"[{timestamp}] USUÁRIO: {usuario_msg}\n")
            f.write(f"[{timestamp}] BOT: {bot_msg}\n")
            f.write("---\n")
    except Exception as e:
        st.warning(f"Erro ao salvar: {e}")

# Função para registrar reserva
RESERVAS_FILE = "reservas.txt"
def registrar_reserva(nome, loja, data, horario, pessoas):
    try:
        timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        with open(RESERVAS_FILE, "a", encoding="utf-8") as f:
            f.write(f"[{timestamp}] Loja: {loja} | Nome: {nome} | Data: {data} | Hora: {horario} | Pessoas: {pessoas}\n")
        return True
    except Exception as e:
        st.error(f"Erro ao salvar reserva: {e}")
        return False

# System prompt melhorado
def get_system_prompt():
    qa_text = "\n".join([f"P: {k}\nR: {v}\n" for k, v in QA_BASE.items()])
    
    return f"""
Você é o assistente do Oahu Pokeshop. Fale em português brasileiro informal mas educado.

REGRAS CRÍTICAS:
1. NUNCA use "querido" ou "querida".
2. Mantenha CONTINUIDADE na conversa - entenda o contexto anterior.
3. Se cliente pergunta sobre poke X, depois sobre preço, BUSQUE NO CARDÁPIO e conecte.
4. Fale sobre produtos de forma DIRETA e EDUCADA, exatamente como está no cardápio.
5. Menos emojis - use apenas quando realmente necessário.
6. Dê "Mahalo" e despeda-se APENAS quando:
   - Cliente tirou todas as dúvidas
   - Cliente fez ou confirmou pedido
   - Cliente pediu o link de pedido
   NÃO use "esperamos vê-lo em breve" em despedidas normais.

DETECÇÃO DE PALAVRAS-CHAVE - MUITO IMPORTANTE:

*** PALAVRAS DE PEDIDO ***
Se mensagem contém: "pedido", "encomendar", "pedir", "fazer pedido", "como encomendar", "onde faz pedido", "onde faço", "quero pedir", "onde está meu pedido", "rastrear", ou qualquer variação de PEDIDO/ENCOMENDA:
RESPONDA DE FORMA OBJETIVA:
"Para fazer seu pedido, acesse: {LINK_PEDIDO}"

*** PALAVRAS DE CARDÁPIO ***
Se mensagem contém: "cardápio", "menu", "o que vocês têm", "qual é o cardápio", "qual é o menu", "quais pratos", "que pokes", "que entradas", "que bebidas", ou qualquer variação de CARDÁPIO/MENU:
RESPONDA DE FORMA OBJETIVA:
"Veja nosso cardápio completo: {LINK_CARDAPIO}"

BASE DE CONHECIMENTO (70 Q&A):
{qa_text}

LOCAIS:
- Matriz SJC: Av. Cassiano Ricardo, 319 - loja 18 - Altos do Esplanada, São José dos Campos, SP
- Jacareí: Av. das Letras, 659 - loja 2, Pátio Villa Branca, Vila Branca
- Taubaté: Av. Charles Schneider, 1400, Vila Costa

Fale naturalmente, seja prestativo, mantenha continuidade e sempre detecte estas palavras-chave.
"""

# Sidebar para API
with st.sidebar:
    st.subheader("Configurações")
    api_key = st.text_input("Cole sua API Key OpenAI:", type="password", help="Obtenha em https://platform.openai.com/api-keys")
    
    if api_key:
        st.success("API carregada")
    else:
        st.warning("Insira sua chave API para usar")
        st.stop()

# Inicializar cliente OpenAI
client = OpenAI(api_key=api_key)

# Inicializar session state
if "historico" not in st.session_state:
    st.session_state.historico = []
    st.session_state.historico.append({"tipo": "bot", "texto": SAUDACAO})

# Exibir histórico
st.markdown("---")
for msg in st.session_state.historico:
    if msg["tipo"] == "user":
        st.markdown(f'<div class="user-msg"><b>Você:</b> {msg["texto"]}</div>', unsafe_allow_html=True)
    else:
        st.markdown(f'<div class="bot-msg"><b>Oahu:</b> {msg["texto"]}</div>', unsafe_allow_html=True)

st.markdown("---")

# Input
col1, col2 = st.columns([0.88, 0.12])
with col1:
    user_input = st.text_input("Sua mensagem:", placeholder="Escreva aqui...", key="msg_input")

with col2:
    botao_enviar = st.button("Enviar", use_container_width=True)

# Processar mensagem
if botao_enviar and user_input:
    st.session_state.historico.append({"tipo": "user", "texto": user_input})
    
    # VERIFICAR PALAVRAS-CHAVE PRIMEIRO
    if detectar_pedido(user_input):
        bot_resposta = f"Para fazer seu pedido, acesse: {LINK_PEDIDO}"
    elif detectar_cardapio(user_input):
        bot_resposta = f"Veja nosso cardápio completo: {LINK_CARDAPIO}"
    else:
        # Chamar OpenAI para resposta normal
        messages = [{"role": "system", "content": get_system_prompt()}]
        for msg in st.session_state.historico:
            role = "user" if msg["tipo"] == "user" else "assistant"
            messages.append({"role": role, "content": msg["texto"]})
        
        try:
            response = client.chat.completions.create(
                model="gpt-3.5-turbo",
                messages=messages,
                max_tokens=500,
                temperature=0.7
            )
            bot_resposta = response.choices[0].message.content.strip()
        except Exception as e:
            bot_resposta = f"Erro ao conectar: {str(e)}\n\nTente novamente."
    
    st.session_state.historico.append({"tipo": "bot", "texto": bot_resposta})
    salvar_chat(user_input, bot_resposta)
    
    # Verificar reserva
    if "reserva" in user_input.lower() or "agendar" in user_input.lower():
        data = re.search(r"(\d{1,2}[/-]\d{1,2}[/-]\d{4})", user_input)
        hora = re.search(r"(\d{1,2}[:]?\d{2})", user_input)
        pessoas = re.search(r"(\d+)\s+(?:pessoas|person)", user_input, re.IGNORECASE)
        
        if data and hora and pessoas:
            registrar_reserva("Cliente", "Matriz SJC", data.group(1), hora.group(1), pessoas.group(1))
    
    st.rerun()

# Rodapé
st.markdown("---")
col1, col2, col3 = st.columns(3)
with col1:
    st.info("Poke Fresco | Saudável")
with col2:
    st.success("3 Lojas | SJC, Jacareí, Taubaté")
with col3:
    st.warning("Seg-Qui 11h30-15h30 | 18h-22h30")

st.caption("Histórico salvo em 'chat_historico.txt' | Reservas em 'reservas.txt' | @oahupokeshop")